SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=[YOUR_SUPABASE_ANON_KEY]
# Use the SESSION POOLER (port 5432) — works from any network including localhost
# Transaction pooler (6543) also works but doesn't support SET/SHOW commands
SUPABASE_DB_URL=postgresql://postgres.[YOUR_PROJECT_REF]:[YOUR_DB_PASSWORD]@[YOUR_POOLER_HOST]:5432/postgres
SUPABASE_JWT_ISSUER=https://your-project-ref.supabase.co/auth/v1
TURNSTILE_SECRET_KEY=[YOUR_TURNSTILE_SECRET_KEY]
FRONTEND_ORIGIN=https://your-app.vercel.app
FAISS_ARTIFACT_URL=https://your-artifact-host/faiss-bundle.tar.gz
FAISS_ARTIFACT_SHA256=[OPTIONAL_SHA256_CHECKSUM]
DATA_DIR=/opt/render/project/src/data

# ── Supabase Management (scripts only — never used by the app at runtime) ─────
# Personal access token from supabase.com/dashboard/account/tokens
SUPABASE_MANAGEMENT_TOKEN=[YOUR_SUPABASE_MANAGEMENT_TOKEN]
